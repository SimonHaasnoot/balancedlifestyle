---
import Layout from '../layouts/Layout.astro';
import PersonalTrainingPage from '../components/pages/PersonalTrainingPage';
---

<Layout
    title="Personal training"
    description="Personal training in Zeist. Persoonlijke begeleiding voor een fitter lichaam en verbeterd zelfbeeld. Gratis intake en proefles."
    pathname="/personal-training/"
    serviceJsonLd={{
        '@context': 'https://schema.org',
        '@type': 'Service',
        name: 'Personal Training',
        description: 'Persoonlijke begeleiding voor een fitter lichaam en verbeterd zelfbeeld. Inclusief voedingsadvies, leefstijlcoaching en trainingsschema op maat.',
        provider: {
            '@type': 'HealthAndBeautyBusiness',
            name: 'Lifestyle & Personal Training Zeist',
            url: 'https://www.lifestylepersonaltraining-zeist.nl',
        },
        areaServed: {
            '@type': 'City',
            name: 'Zeist',
        },
        serviceType: 'Personal Training',
        url: 'https://www.lifestylepersonaltraining-zeist.nl/personal-training/',
        offers: {
            '@type': 'Offer',
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
        },
    }}
>
    <PersonalTrainingPage client:only="react" />
    </Layout>
