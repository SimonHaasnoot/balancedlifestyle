---
import Layout from '../layouts/Layout.astro';
import CommunityPage from '../components/pages/CommunityPage';

const faq = [
    { question: 'Wat is de community bij Lifestyle & Personal Training Zeist?', answer: 'Onze community is een hechte groep van mensen die samen trainen en groeien. Je bent niet alleen lid van een sportschool, maar onderdeel van een sportieve en sociale groep die elkaar motiveert.' },
    { question: 'Organiseren jullie events buiten de trainingen?', answer: 'Ja! We organiseren regelmatig sociale momenten zoals kerstborrels en gezamenlijke sportevents. Dit versterkt de band en maakt trainen nog leuker.' },
    { question: 'Is de community geschikt voor beginners?', answer: 'Absoluut. Of je nu net begint of al jaren traint, iedereen is welkom. De groep motiveert elkaar ongeacht niveau.' },
    { question: 'Hoe kan ik onderdeel worden van de community?', answer: 'Door je aan te melden voor personal training of groepstraining bij ons word je automatisch onderdeel van de community. Neem contact op voor een gratis kennismaking.' },
];

const communityJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'SportsActivityLocation',
    name: 'Lifestyle & Personal Training Zeist – Community',
    url: 'https://lifestylepersonaltraining-zeist.nl/community/',
    description: 'Word onderdeel van onze sportieve community in Zeist. Samen trainen, samen groeien. Personal training in een hechte, betrokken groep.',
    address: {
        '@type': 'PostalAddress',
        addressLocality: 'Zeist',
        addressCountry: 'NL',
    },
};
---

<Layout
    title="Sport Community Zeist | Samen Trainen & Groeien | Personal Training"
    description="Word onderdeel van onze sportieve community in Zeist. Samen trainen, samen groeien in een hechte groep met personal training. Events, sportdagen en dagelijkse support. Meld je aan!"
    pathname="/community/"
    serviceJsonLd={communityJsonLd}
    faqJsonLd={faq}
>
    <CommunityPage client:only="react" />

    <section class="seo-content" aria-label="Community Lifestyle & Personal Training Zeist">
        <h2>Community – Samen Trainen, Samen Groeien in Zeist</h2>
        <p>Bij Lifestyle & Personal Training Zeist draait het niet alleen om trainen, maar om samen groeien. We bouwen aan een omgeving waar iedereen zich welkom en thuis voelt, elkaar motiveert en het beste in elkaar naar boven haalt.</p>
        <p>Onze community bestaat uit mensen met dezelfde mindset: werken aan jezelf, fysiek én mentaal. Er is ruimte voor een grap, maar ook voor groei, focus en discipline.</p>
        <h3>Wat maakt onze community bijzonder?</h3>
        <ul>
            <li>Samen trainen in een hechte, betrokken groep</li>
            <li>Support en saamhorigheid staan centraal</li>
            <li>Ruimte voor groei, focus en discipline</li>
            <li>Gezamenlijke events zoals kerstborrels en sportevents</li>
            <li>Niet alleen een studio, maar een sportieve en sociale groep</li>
        </ul>
        <h3>Events en verbinding</h3>
        <p>Naast de trainingen organiseren we momenten om de band binnen de community te versterken. Denk aan gezellige kerstborrels en gezamenlijke sportevents waar plezier en verbinding centraal staan.</p>
    </section>

    <style>
        .seo-content {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
    </style>
</Layout>
