---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    return posts.map((post) => ({
        params: { slug: post.id.replace(/\.(md|mdx)$/, '') },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const slug = post.id.replace(/\.(md|mdx)$/, '');
const formattedDate = new Intl.DateTimeFormat('nl-NL', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
}).format(post.data.date);

const articleJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    datePublished: post.data.date.toISOString(),
    author: {
        '@type': 'Person',
        name: 'Sem van de Griendt',
        url: 'https://lifestylepersonaltraining-zeist.nl/over-sem/',
    },
    publisher: {
        '@type': 'Organization',
        name: 'Lifestyle & Personal Training Zeist',
        url: 'https://lifestylepersonaltraining-zeist.nl',
    },
    mainEntityOfPage: `https://lifestylepersonaltraining-zeist.nl/blogs/${slug}/`,
    keywords: post.data.tags?.join(', '),
};
---

<Layout
    title={post.data.title}
    description={`${post.data.title} – Blog van Lifestyle & Personal Training Zeist over ${post.data.tags?.slice(0, 2).join(' en ').toLowerCase() || 'fitness en leefstijl'}.`}
    pathname={`/blogs/${slug}/`}
    serviceJsonLd={articleJsonLd}
>
    <main class="blog-page">
        <article class="blog-article" itemscope itemtype="https://schema.org/BlogPosting">
            <header class="blog-header">
                <div class="blog-header-inner">
                    <nav class="blog-breadcrumb" aria-label="Breadcrumb">
                        <a href="/">Home</a>
                        <span class="breadcrumb-sep">›</span>
                        <a href="/blogs/">Blogs</a>
                        <span class="breadcrumb-sep">›</span>
                        <span class="breadcrumb-current">{post.data.title}</span>
                    </nav>
                    <div class="blog-meta">
                        <time class="blog-date" datetime={post.data.date.toISOString()} itemprop="datePublished">{formattedDate}</time>
                        {post.data.tags && post.data.tags.length > 0 && (
                            <div class="blog-tags">
                                {post.data.tags.map((tag: string) => (
                                    <span class="blog-tag">{tag}</span>
                                ))}
                            </div>
                        )}
                    </div>
                    <h1 class="blog-title" itemprop="headline">{post.data.title}</h1>
                </div>
            </header>

            {post.data.image && (
                <div class="blog-hero-image">
                    <img src={post.data.image} alt={post.data.title} loading="eager" />
                </div>
            )}

            <div class="blog-content" itemprop="articleBody">
                <Content />
            </div>

            <footer class="blog-footer">
                <div class="blog-author">
                    <span class="blog-author-label">Geschreven door</span>
                    <a href="/over-sem/" class="blog-author-name" itemprop="author">Sem van de Griendt</a>
                    <span class="blog-author-role">Personal Trainer & Leefstijlcoach</span>
                </div>
                <div class="blog-nav-links">
                    <a class="blog-back" href="/blogs/">← Alle blogs</a>
                    <a class="blog-back blog-back--home" href="/">← Home</a>
                </div>
            </footer>
        </article>
    </main>
</Layout>

<style>
    .blog-page {
        background: #111;
        min-height: 100vh;
    }

    .blog-header {
        background: linear-gradient(135deg, #151515 0%, #1a2a32 100%);
        padding: 8rem 1.5rem 3rem;
    }

    .blog-header-inner {
        max-width: 800px;
        margin: 0 auto;
    }

    .blog-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        font-family: 'Nunito', sans-serif;
        font-size: 0.85rem;
    }

    .blog-breadcrumb a {
        color: #888;
        text-decoration: none;
        transition: color 0.2s;
    }

    .blog-breadcrumb a:hover {
        color: #5ab7db;
    }

    .breadcrumb-sep {
        color: #555;
    }

    .breadcrumb-current {
        color: #ccc;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        max-width: 300px;
    }

    .blog-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
    }

    .blog-date {
        font-family: 'Nunito', sans-serif;
        font-size: 0.9rem;
        color: #888;
    }

    .blog-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .blog-tag {
        font-family: 'Nunito', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        color: #5ab7db;
        background: rgba(90, 183, 219, 0.1);
        padding: 0.25rem 0.75rem;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .blog-title {
        font-family: 'Exo', sans-serif;
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 700;
        color: #fff;
        line-height: 1.3;
        margin: 0;
    }

    .blog-hero-image {
        max-width: 800px;
        margin: -2rem auto 0;
        padding: 0 1.5rem;
    }

    .blog-hero-image img {
        width: 100%;
        height: auto;
        max-height: 400px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .blog-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        color: #e0e0e0;
        font-family: 'Nunito', sans-serif;
        font-size: 1.05rem;
        line-height: 1.9;
    }

    .blog-content :global(h2) {
        font-family: 'Exo', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: #fff;
        margin: 2.5rem 0 1rem;
    }

    .blog-content :global(h3) {
        font-family: 'Exo', sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: #5ab7db;
        margin: 2rem 0 0.75rem;
    }

    .blog-content :global(p) {
        margin-bottom: 1.25rem;
    }

    .blog-content :global(ul),
    .blog-content :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
    }

    .blog-content :global(li) {
        margin-bottom: 0.5rem;
    }

    .blog-content :global(strong) {
        color: #fff;
    }

    .blog-content :global(a) {
        color: #5ab7db;
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .blog-content :global(a:hover) {
        color: #90cee6;
    }

    .blog-content :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 1.5rem 0;
    }

    .blog-content :global(blockquote) {
        border-left: 3px solid #5ab7db;
        padding-left: 1.5rem;
        margin: 1.5rem 0;
        color: #aaa;
        font-style: italic;
    }

    .blog-footer {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 1.5rem 5rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        flex-wrap: wrap;
        gap: 2rem;
        border-top: 1px solid #2a2a2a;
        padding-top: 2rem;
    }

    .blog-author {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .blog-author-label {
        font-family: 'Nunito', sans-serif;
        font-size: 0.8rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .blog-author-name {
        font-family: 'Exo', sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: #fff;
        text-decoration: none;
    }

    .blog-author-name:hover {
        color: #5ab7db;
    }

    .blog-author-role {
        font-family: 'Nunito', sans-serif;
        font-size: 0.85rem;
        color: #888;
    }

    .blog-nav-links {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .blog-back {
        font-family: 'Exo', sans-serif;
        display: inline-block;
        padding: 0.75rem 1.5rem;
        color: #fff;
        background: #5ab7db;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: background 0.2s, transform 0.2s;
    }

    .blog-back--home {
        background: transparent;
        border: 1px solid #5ab7db;
        color: #5ab7db;
    }

    .blog-back:hover {
        background: #4aa3c5;
        color: #fff;
        transform: translateY(-1px);
    }
</style>
