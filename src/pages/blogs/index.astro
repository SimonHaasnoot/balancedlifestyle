---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getBlogImageMap } from '../../data/blogImages';

const posts = await getCollection('blog');
const imageMap = getBlogImageMap(posts);

const stripMarkdown = (body: string) =>
    body
        .replace(/```[\s\S]*?```/g, ' ')
        .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
        .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
        .replace(/[#>*_`~|-]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

const blogs = posts
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .map((post) => {
        const slug = post.id.replace(/\.(md|mdx)$/, '');
        const plain = stripMarkdown(post.body ?? '');
        const wordCount = plain ? plain.split(' ').length : 0;
        const excerpt =
            post.data.description ??
            (plain.length > 160 ? `${plain.slice(0, 160).trim()}…` : plain);
        return {
            slug,
            title: post.data.title,
            image: imageMap.get(slug)!,
            tags: post.data.tags || [],
            excerpt,
            readingTime: Math.max(1, Math.round(wordCount / 200)),
            date: post.data.date,
            dateLabel: new Intl.DateTimeFormat('nl-NL', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
            }).format(post.data.date),
        };
    });

const allTags = [...new Set(blogs.flatMap((b) => b.tags))].sort((a, b) =>
    a.localeCompare(b),
);
---

<Layout
    title="Blog | Tips over Fitness, Voeding & Leefstijl"
    description="Lees blogs over fitness, voeding, een gebalanceerde leefstijl en sport van je personal trainer in Zeist. Tips voor een gezonder leven."
    pathname="/blogs/"
>
    <main class="blogs-page">
        <header class="blogs-hero">
            <div class="blogs-hero-inner">
                <span class="blogs-eyebrow">Kennis & inspiratie</span>
                <h1>De Blog</h1>
                <p>
                    Praktische tips over fitness, voeding en een gebalanceerde
                    leefstijl — geschreven door je personal trainer in Zeist.
                </p>
            </div>
        </header>

        <section class="blogs-grid-section">
            <div class="blogs-container">
                {blogs.length === 0 && (
                    <p class="blogs-empty">Er zijn nog geen blogs gepubliceerd.</p>
                )}

                {blogs.length > 0 && (
                    <div class="blogs-toolbar">
                        <div class="blogs-search">
                            <svg
                                class="blogs-search-icon"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                aria-hidden="true"
                            >
                                <circle cx="11" cy="11" r="7"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                            <input
                                type="search"
                                id="blog-search"
                                placeholder="Zoek een artikel…"
                                autocomplete="off"
                                aria-label="Zoek in blogs"
                            />
                        </div>
                        <div class="blogs-filters" role="group" aria-label="Filter op onderwerp">
                            <button class="blog-chip is-active" data-tag="all" type="button">
                                Alles
                            </button>
                            {allTags.map((tag) => (
                                <button class="blog-chip" data-tag={tag} type="button">
                                    {tag}
                                </button>
                            ))}
                        </div>
                    </div>
                )}

                <p class="blogs-noresults" id="blog-noresults" hidden>
                    Geen artikelen gevonden. Probeer een andere zoekterm of filter.
                </p>

                <div class="blogs-grid" id="blog-grid">
                    {blogs.map((blog, index) => (
                        <a
                            href={`/blogs/${blog.slug}/`}
                            class={`blog-card ${index === 0 ? 'blog-card--featured' : ''}`}
                            data-title={blog.title.toLowerCase()}
                            data-tags={blog.tags.join('|').toLowerCase()}
                            data-text={blog.excerpt.toLowerCase()}
                        >
                            <div class="blog-card-image">
                                <img
                                    src={blog.image}
                                    alt={blog.title}
                                    loading={index < 3 ? 'eager' : 'lazy'}
                                />
                                <span class="blog-card-readtime">{blog.readingTime} min lezen</span>
                            </div>
                            <div class="blog-card-content">
                                <div class="blog-card-tags">
                                    {blog.tags.slice(0, 3).map((tag: string) => (
                                        <span class="blog-tag">{tag}</span>
                                    ))}
                                </div>
                                <h2 class="blog-card-title">{blog.title}</h2>
                                <p class="blog-card-excerpt">{blog.excerpt}</p>
                                <div class="blog-card-foot">
                                    <time class="blog-card-date" datetime={blog.date.toISOString()}>
                                        {blog.dateLabel}
                                    </time>
                                    <span class="blog-card-cta">Lees meer →</span>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    const search = document.getElementById('blog-search') as HTMLInputElement | null;
    const grid = document.getElementById('blog-grid');
    const noResults = document.getElementById('blog-noresults');
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.blog-chip'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.blog-card'));

    let activeTag = 'all';
    let query = '';

    function apply() {
        let visible = 0;
        cards.forEach((card) => {
            const matchesTag =
                activeTag === 'all' ||
                (card.dataset.tags ?? '').split('|').includes(activeTag.toLowerCase());
            const haystack = `${card.dataset.title ?? ''} ${card.dataset.tags ?? ''} ${card.dataset.text ?? ''}`;
            const matchesQuery = query === '' || haystack.includes(query);
            const show = matchesTag && matchesQuery;
            card.style.display = show ? '' : 'none';
            // De 'featured' (brede) kaart alleen breed laten als er niet gefilterd wordt.
            if (card.classList.contains('blog-card--featured')) {
                card.classList.toggle('blog-card--featured-off', activeTag !== 'all' || query !== '');
            }
            if (show) visible++;
        });
        if (noResults) noResults.hidden = visible !== 0;
    }

    search?.addEventListener('input', () => {
        query = search.value.trim().toLowerCase();
        apply();
    });

    chips.forEach((chip) => {
        chip.addEventListener('click', () => {
            chips.forEach((c) => c.classList.remove('is-active'));
            chip.classList.add('is-active');
            activeTag = chip.dataset.tag ?? 'all';
            apply();
        });
    });
</script>

<style>
    .blogs-page {
        background: #111;
        min-height: 100vh;
    }

    .blogs-hero {
        background: linear-gradient(135deg, #151515 0%, #1a2a32 100%);
        padding: 8rem 1.5rem 3.5rem;
        text-align: center;
    }

    .blogs-hero-inner {
        max-width: 720px;
        margin: 0 auto;
    }

    .blogs-eyebrow {
        display: inline-block;
        font-family: 'Nunito', sans-serif;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #5ab7db;
        margin-bottom: 1rem;
    }

    .blogs-hero h1 {
        font-family: 'Exo', sans-serif;
        font-size: clamp(2.5rem, 6vw, 3.75rem);
        font-weight: 700;
        color: #fff;
        margin: 0 0 1rem;
        line-height: 1.1;
    }

    .blogs-hero p {
        font-family: 'Nunito', sans-serif;
        font-size: 1.1rem;
        color: #9fb9c4;
        line-height: 1.6;
        margin: 0;
    }

    .blogs-grid-section {
        padding: 2.5rem 1.5rem 5rem;
    }

    .blogs-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .blogs-empty {
        color: #999;
        text-align: center;
        font-size: 1.1rem;
    }

    /* Toolbar: search + tag chips */
    .blogs-toolbar {
        position: sticky;
        top: 0;
        z-index: 20;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1.25rem 0;
        margin-bottom: 2rem;
        background: rgba(17, 17, 17, 0.92);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid #242424;
    }

    .blogs-search {
        position: relative;
        max-width: 460px;
        width: 100%;
    }

    .blogs-search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        width: 1.1rem;
        height: 1.1rem;
        color: #6f8a95;
        pointer-events: none;
    }

    .blogs-search input {
        width: 100%;
        box-sizing: border-box;
        padding: 0.85rem 1rem 0.85rem 2.75rem;
        font-family: 'Nunito', sans-serif;
        font-size: 1rem;
        color: #fff;
        background: #1c1d1f;
        border: 1px solid #2e2e2e;
        border-radius: 100px;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .blogs-search input::placeholder {
        color: #777;
    }

    .blogs-search input:focus {
        border-color: #5ab7db;
        box-shadow: 0 0 0 3px rgba(90, 183, 219, 0.15);
    }

    .blogs-filters {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .blog-chip {
        font-family: 'Nunito', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        color: #b8c4ca;
        background: #1c1d1f;
        border: 1px solid #2e2e2e;
        padding: 0.45rem 1rem;
        border-radius: 100px;
        cursor: pointer;
        transition: all 0.18s ease;
    }

    .blog-chip:hover {
        border-color: #5ab7db;
        color: #fff;
    }

    .blog-chip.is-active {
        background: #5ab7db;
        border-color: #5ab7db;
        color: #0d0d0d;
    }

    .blogs-noresults {
        color: #999;
        text-align: center;
        font-family: 'Nunito', sans-serif;
        font-size: 1.05rem;
        padding: 2rem 0;
    }

    /* Grid */
    .blogs-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.75rem;
    }

    @media (min-width: 640px) {
        .blogs-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .blogs-grid {
            grid-template-columns: repeat(3, 1fr);
        }
        .blog-card--featured:not(.blog-card--featured-off) {
            grid-column: span 2;
            grid-row: span 2;
        }
        .blog-card--featured:not(.blog-card--featured-off) .blog-card-image {
            height: 340px;
        }
        .blog-card--featured:not(.blog-card--featured-off) .blog-card-title {
            font-size: 1.7rem;
        }
        .blog-card--featured:not(.blog-card--featured-off) .blog-card-excerpt {
            -webkit-line-clamp: 4;
            line-clamp: 4;
        }
    }

    .blog-card {
        display: flex;
        flex-direction: column;
        background: #1a1b1d;
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        border: 1px solid #262626;
    }

    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 48px rgba(90, 183, 219, 0.12);
        border-color: #5ab7db;
    }

    .blog-card-image {
        position: relative;
        width: 100%;
        height: 210px;
        overflow: hidden;
    }

    .blog-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .blog-card:hover .blog-card-image img {
        transform: scale(1.06);
    }

    .blog-card-readtime {
        position: absolute;
        bottom: 0.75rem;
        left: 0.75rem;
        font-family: 'Nunito', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        color: #fff;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        padding: 0.25rem 0.7rem;
        border-radius: 100px;
        letter-spacing: 0.3px;
    }

    .blog-card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .blog-card-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.85rem;
    }

    .blog-tag {
        font-family: 'Nunito', sans-serif;
        font-size: 0.72rem;
        font-weight: 700;
        color: #5ab7db;
        background: rgba(90, 183, 219, 0.1);
        padding: 0.25rem 0.7rem;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .blog-card-title {
        font-family: 'Exo', sans-serif;
        font-size: 1.25rem;
        font-weight: 600;
        color: #fff;
        margin: 0 0 0.6rem;
        line-height: 1.35;
    }

    .blog-card-excerpt {
        font-family: 'Nunito', sans-serif;
        font-size: 0.95rem;
        color: #9aa6ac;
        line-height: 1.6;
        margin: 0 0 1.25rem;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 3;
        line-clamp: 3;
        overflow: hidden;
    }

    .blog-card-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-top: auto;
        padding-top: 0.5rem;
    }

    .blog-card-date {
        font-family: 'Nunito', sans-serif;
        font-size: 0.82rem;
        color: #777;
    }

    .blog-card-cta {
        font-family: 'Exo', sans-serif;
        font-size: 0.9rem;
        font-weight: 600;
        color: #5ab7db;
        transition: color 0.2s;
    }

    .blog-card:hover .blog-card-cta {
        color: #90cee6;
    }
</style>
