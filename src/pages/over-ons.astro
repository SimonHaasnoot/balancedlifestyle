---
import Layout from '../layouts/Layout.astro';
import OverOnsPage from '../components/pages/OverOnsPage';

const faq = [
    { question: 'Wie zitten er achter Lifestyle & Personal Training Zeist?', answer: 'Wij zijn een team van gecertificeerde personal trainers en leefstijlcoaches in Zeist. We geloven in persoonlijke aandacht, duurzame resultaten en een veilige omgeving.' },
    { question: 'Wat maakt jullie anders dan een gewone sportschool?', answer: 'Geen massale sportschool, maar een plek waar jij centraal staat. We werken met een vast klantenbestand, bieden begeleiding op maat en combineren training met leefstijlcoaching.' },
    { question: 'Werken jullie met standaard trainingsschema\'s?', answer: 'Nee, onze aanpak is volledig op maat. Geen standaard schema\'s, maar begeleiding die aansluit op jouw doelen, niveau en levensstijl.' },
    { question: 'Wat is jullie missie?', answer: 'Wij zijn ervan overtuigd dat echte verandering ontstaat door consistentie, duidelijke afspraken en een veilige omgeving. Door goede gewoontes help je op lange termijn je gezondheidsdoelen behalen.' },
];

const organizationJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'HealthAndBeautyBusiness',
    name: 'Lifestyle & Personal Training Zeist',
    url: 'https://lifestylepersonaltraining-zeist.nl',
    description: 'Persoonlijke begeleiding in krachttraining en leefstijlcoaching in Zeist. Volledig op maat, geen standaard schemas.',
    address: {
        '@type': 'PostalAddress',
        addressLocality: 'Zeist',
        addressCountry: 'NL',
    },
    knowsAbout: ['Personal Training', 'Leefstijlcoaching', 'Voedingsadvies', 'Krachttraining', 'Mentale Coaching'],
};
---

<Layout
    title="Over Ons | Personal Trainers Zeist | Lifestyle & Personal Training"
    description="Maak kennis met het team achter Lifestyle & Personal Training Zeist. Persoonlijke begeleiding op maat, geen standaard schema's. Ontdek onze aanpak en kernwaarden."
    pathname="/over-ons/"
    serviceJsonLd={organizationJsonLd}
    faqJsonLd={faq}
>
    <OverOnsPage client:only="react" />

    <section class="seo-content" aria-label="Over Lifestyle & Personal Training Zeist">
        <h2>Over Ons – Lifestyle & Personal Training Zeist</h2>
        <p>Bij Lifestyle & Personal Training Zeist geloven wij dat krachttraining meer is dan alleen bewegen. Het is een investering in jezelf.</p>
        <p>Onze aanpak is volledig op maat. Geen standaard schema's, maar begeleiding die aansluit op jouw doelen, niveau en levensstijl.</p>
        <h3>Wat ons onderscheidt</h3>
        <ul>
            <li>Persoonlijke aandacht en scherp advies op basis van jouw context</li>
            <li>Betrokken en vast klantenbestand</li>
            <li>Geen massale sportschool maar een plek waar jij centraal staat</li>
            <li>Continuïteit, progressie en plezier staan voorop</li>
            <li>Duurzame resultaten door goede gewoontes</li>
        </ul>
    </section>

    <style>
        .seo-content {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
    </style>
</Layout>
